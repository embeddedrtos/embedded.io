{
  "name": "author-validator",
  "version": "1.0.0",
  "description": "Validate author.json with JSON Schema using ajv-cli",
  "scripts": {
    "validate:author": "ajv validate -s authors/schema.json -d authors/authors.json --strict=false --spec=draft2020"
  },
  "devDependencies": {
    "ajv-cli": "^5.0.0"
  }
}
